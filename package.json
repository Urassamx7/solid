{
	"name": "solid",
	"description": "GymPass style app",
	"main": "index.js",
	"type": "commonjs",
	"private": true,
	"keywords": [],
	"license": "ISC",
	"author": {
		"email": "marvin.lagas0123@gmail.com",
		"name": "Marvin Mussacate",
		"url": "https://github.com/Urassamx7"
	},
	"scripts": {
		"start:dev": "tsx watch src/server.ts",
		"build": "tsup src --format cjs --out-dir dist --clean",
		"start": "node dist/server.js",
		"format": "bunx --bun @biomejs/biome format --write",
		"lint": "bunx --bun @biomejs/biome lint --write",
		"check": "bunx --bun @biomejs/biome check --write",
		"db:studio": "prisma studio",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:deploy": "prisma migrate deploy",
		"db:reset": "prisma migrate reset",
		"test": "vitest run --project unit",
		"test:e2e": "vitest run --project e2e",
		"test:watch": "vitest --project unit",
		"test:e2e:watch": "vitest --project e2e",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui"
	},
	"dependencies": {
		"@fastify/jwt": "^10.1.0",
		"@prisma/client": "6",
		"@tsconfig/node24": "^24.0.4",
		"bcryptjs": "^3.0.3",
		"dayjs": "^1.11.21",
		"dotenv": "^17.4.2",
		"fastify": "^5.8.5",
		"fastify-type-provider-zod": "^6.1.0",
		"tsup": "^8.5.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@types/bun": "latest",
		"@types/node": "^26.0.0",
		"@vitest/coverage-v8": "4.1.8",
		"@vitest/ui": "^4.1.8",
		"prisma": "6",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.8"
	}
}
