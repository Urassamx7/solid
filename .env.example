# ===== Database =====
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/solid_db"

# ===== JWT (JSON Web Token) =====
# Secret key for JWT signing (generate a strong random string in production)
JWT_SECRET_KEY="your-super-secret-jwt-key-change-in-production"

# Token expiration time (examples: "7d", "24h", "1w")
JWT_EXP_IN="7d"

# ===== Server =====
# Port the application will listen on
PORT="3000"

# Node environment (development, test, production)
NODE_ENV="development"

# ===== Additional Notes =====
# - For local development with Docker, DATABASE_URL should point to localhost:5432
# - Run `docker compose up -d` to start PostgreSQL
# - After setup, run `npm run db:migrate` to apply migrations
# - Generate Prisma Client with `npm run db:generate`
# - Never commit real JWT secrets or passwords — use strong, unique values